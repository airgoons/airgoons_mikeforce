							init="this addAction [""<t color='#ff0000' shadowColor='#000000' shadowOffset='0.15'>PARADROP</t>"","" " \n " _target = _this select 0; " \n " _caller = _this select 1; " \n " " \n " _pos = getPos _target; " \n " _speed = 2 * -(speed _target); " \n " _vel = velocity _target; " \n " _dir = direction _target; " \n "  " \n " _caller action ['Eject', vehicle _caller]; " \n "  " \n " waitUntil {vehicle _caller == _caller}; " \n "  " \n " sleep 1; " \n " " \n " _chute = CreateVehicle ['vn_b_parachute_01_02', (getPos _caller), [], (_dir -180), 'CAN_COLLIDE']; " \n "  " \n " _caller assignAsDriver _chute; " \n " _caller moveInDriver _chute; " \n "  " \n " _chute setVelocity [ " \n "  (_vel select 0) + (sin _dir * _speed), " \n "  (_vel select 1) + (cos _dir * _speed), " \n "  (_vel select 2) " \n " ]; " \n "  " \n " if (_target emptyPositions 'cargo' > 29) then { " \n "  " \n "   " \n "  _pos = getPos _target; " \n "  _speed = 2 * -(speed _target); " \n "  _vel = velocity _target; " \n "  _dir = direction _target; " \n " " \n "  _chute = CreateVehicle ['vn_b_parachute_01_02', _pos, [], 0]; " \n "   " \n "  _crate = CreateVehicle ['IG_supplyCrate_F', [0,0,0], [],0]; " \n "   " \n "  _crate attachTo [_chute,[0,0,0]]; " \n "   " \n "  clearWeaponCargoGlobal _crate; " \n "  clearMagazineCargoGlobal _crate; " \n "  clearItemCargoGlobal _crate; " \n "  clearBackpackCargoGlobal _crate; " \n " " \n "  { " \n "    _crate addWeaponCargoGlobal _x; " \n "  } forEach [['vn_m72', 2],['vn_m_axe_01', 1]]; " \n " " \n "  { " \n "    _crate addMagazineCargoGlobal _x; " \n "  } forEach [['vn_m16_20_mag', 50], ['vn_m60_100_mag', 10], ['vn_m67_grenade_mag', 10], ['vn_40mm_m381_he_mag', 10], ['vn_40mm_m433_hedp_mag', 10], ['vn_40mm_m680_smoke_w_mag', 10], ['vn_40mm_m583_flare_w_mag', 10], ['vn_prop_med_painkillers', 10], ['vn_prop_med_antivenom', 10], ['vn_prop_med_antimalaria', 10], ['vn_m1911_mag', 10],['vn_m72_mag',2]]; " \n " " \n "  { " \n "    _crate addItemCargoGlobal _x; " \n "  } forEach [['vn_b_item_firstaidkit', 20]]; " \n " " \n "  { " \n "    _crate addBackpackCargoGlobal _x; " \n "  } forEach [['vn_b_pack_static_m29_01', 1], ['vn_b_pack_static_base_01', 1]]; " \n "   " \n "   " \n "  _chute setVelocity [ " \n "   (_vel select 0) + (sin _dir * _speed), " \n "   (_vel select 1) + (cos _dir * _speed), " \n "   (_vel select 2) " \n "  ]; " \n "   " \n " " \n "   " \n "  _chem1 = 'Chemlight_green' CreateVehicle (getPos _crate); " \n "  _chem1 attachto [_crate,[0,0.38,0.3]]; " \n "  _chem1 setVectorDirAndUp [[0,1,3],[0,0,1]]; " \n "   " \n "  _chem2 = 'Chemlight_green' CreateVehicle (getPos _crate); " \n "  _chem2 attachto [_crate,[0,-0.38,0.3]]; " \n "  _chem2 setVectorDirAndUp [[0,1,3],[0,0,1]]; " \n "   " \n "   " \n "  while {(getPosATL _chute select 2) > 30} do {  " \n "   _flare = 'F_40mm_Green' createVehicle (getPos _crate); " \n "   _flare attachTo [_crate,[0,0,0.45]]; " \n "   sleep 11; " \n "  }; " \n "   " \n "  waitUntil {(getPosATL _chute select 2) < 30}; " \n "   " \n "  _smoke = 'G_40mm_SmokeGreen' createVehicle (getPos _crate); " \n "  _smoke attachTo [_crate,[0,0,0.45]]; " \n " }; " \n " " \n """,nil,10,true,true,"""",""(((_target getCargoIndex _this == 0) || (_target getCargoIndex _this == 1)) && ((getPosASL _target) select 2 > 150))"",-1];";
